{
  "version": "2.0.0",
  "tasks": [

    {
      "label": "HMS: Build (Debug)",
      "type": "shell",
      "command": "make build BUILD_TYPE=Debug",
      "group": { "kind": "build", "isDefault": true },
      "presentation": {
        "echo": false,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "options": {
        "env": { "TERM": "xterm-256color" }
      },
      "problemMatcher": {
        "owner": "cpp",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
          "file": 1, "line": 2, "column": 3, "severity": 4, "message": 5
        }
      },
      "icon": { "id": "tools", "color": "terminal.ansiCyan" }
    },

    {
      "label": "HMS: Build (Release)",
      "type": "shell",
      "command": "make release",
      "group": "build",
      "presentation": {
        "echo": false, "reveal": "always", "panel": "shared", "clear": true
      },
      "options": { "env": { "TERM": "xterm-256color" } },
      "problemMatcher": ["$gcc"],
      "icon": { "id": "tools", "color": "terminal.ansiGreen" }
    },

    {
      "label": "HMS: Configure (Debug)",
      "type": "shell",
      "command": "make configure BUILD_TYPE=Debug",
      "group": "build",
      "presentation": {
        "echo": false, "reveal": "always", "panel": "shared", "clear": true
      },
      "options": { "env": { "TERM": "xterm-256color" } },
      "problemMatcher": [],
      "icon": { "id": "gear", "color": "terminal.ansiCyan" }
    },

    {
      "label": "HMS: Configure (Release)",
      "type": "shell",
      "command": "make configure BUILD_TYPE=Release BUILD_DIR=build-release",
      "group": "build",
      "presentation": {
        "echo": false, "reveal": "always", "panel": "shared", "clear": true
      },
      "options": { "env": { "TERM": "xterm-256color" } },
      "problemMatcher": [],
      "icon": { "id": "gear", "color": "terminal.ansiGreen" }
    },

    {
      "label": "HMS: Rebuild (Clean + Build)",
      "type": "shell",
      "command": "make rebuild",
      "group": "build",
      "presentation": {
        "echo": false, "reveal": "always", "panel": "shared", "clear": true
      },
      "options": { "env": { "TERM": "xterm-256color" } },
      "problemMatcher": ["$gcc"],
      "icon": { "id": "refresh", "color": "terminal.ansiYellow" }
    },

    {
      "label": "HMS: Run (Debug)",
      "type": "shell",
      "command": "make run BUILD_TYPE=Debug",
      "group": { "kind": "test", "isDefault": true },
      "presentation": {
        "echo": false, "reveal": "always", "focus": true,
        "panel": "dedicated", "clear": true
      },
      "options": {
        "env": {
          "TERM": "xterm-256color",
          "QT_LOGGING_RULES": "qt.qpa.*=false",
          "XDG_RUNTIME_DIR": "/tmp/runtime-${env:UID}"
        }
      },
      "problemMatcher": [],
      "icon": { "id": "play", "color": "terminal.ansiCyan" }
    },

    {
      "label": "HMS: Run (Release)",
      "type": "shell",
      "command": "make run-release",
      "group": "test",
      "presentation": {
        "echo": false, "reveal": "always", "focus": true,
        "panel": "dedicated", "clear": true
      },
      "options": {
        "env": {
          "TERM": "xterm-256color",
          "QT_LOGGING_RULES": "qt.qpa.*=false",
          "XDG_RUNTIME_DIR": "/tmp/runtime-${env:UID}"
        }
      },
      "problemMatcher": [],
      "icon": { "id": "play", "color": "terminal.ansiGreen" }
    },

    {
      "label": "HMS: Clean",
      "type": "shell",
      "command": "make clean",
      "group": "build",
      "presentation": {
        "echo": false, "reveal": "always", "panel": "shared", "clear": false
      },
      "options": { "env": { "TERM": "xterm-256color" } },
      "problemMatcher": [],
      "icon": { "id": "trash", "color": "terminal.ansiRed" }
    },

    {
      "label": "HMS: Clean All",
      "type": "shell",
      "command": "make clean-all",
      "group": "build",
      "presentation": {
        "echo": false, "reveal": "always", "panel": "shared", "clear": false
      },
      "options": { "env": { "TERM": "xterm-256color" } },
      "problemMatcher": [],
      "icon": { "id": "trash", "color": "terminal.ansiRed" }
    },

    {
      "label": "HMS: Format Code",
      "type": "shell",
      "command": "make format",
      "group": "build",
      "presentation": {
        "echo": false, "reveal": "always", "panel": "shared", "clear": false
      },
      "options": { "env": { "TERM": "xterm-256color" } },
      "problemMatcher": [],
      "icon": { "id": "symbol-color", "color": "terminal.ansiMagenta" }
    },

    {
      "label": "HMS: Lint (cppcheck)",
      "type": "shell",
      "command": "make lint",
      "group": "build",
      "presentation": {
        "echo": false, "reveal": "always", "panel": "shared", "clear": true
      },
      "options": { "env": { "TERM": "xterm-256color" } },
      "problemMatcher": {
        "owner": "cppcheck",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^\\[(.+):(\\d+)\\]:\\s+\\((\\w+)\\)\\s+(.+)$",
          "file": 1, "line": 2, "severity": 3, "message": 4
        }
      },
      "icon": { "id": "search", "color": "terminal.ansiYellow" }
    },

    {
      "label": "HMS: Check Dependencies",
      "type": "shell",
      "command": "make check-deps",
      "group": "build",
      "presentation": {
        "echo": false, "reveal": "always", "panel": "shared", "clear": true
      },
      "options": { "env": { "TERM": "xterm-256color" } },
      "problemMatcher": [],
      "icon": { "id": "checklist", "color": "terminal.ansiCyan" }
    },

    {
      "label": "HMS: Show Info",
      "type": "shell",
      "command": "make info",
      "group": "build",
      "presentation": {
        "echo": false, "reveal": "always", "panel": "shared", "clear": false
      },
      "options": { "env": { "TERM": "xterm-256color" } },
      "problemMatcher": [],
      "icon": { "id": "info", "color": "terminal.ansiBlue" }
    },

    {
      "label": "HMS: Package (Release tarball)",
      "type": "shell",
      "command": "make package",
      "group": "build",
      "presentation": {
        "echo": false, "reveal": "always", "panel": "shared", "clear": true
      },
      "options": { "env": { "TERM": "xterm-256color" } },
      "problemMatcher": [],
      "icon": { "id": "package", "color": "terminal.ansiGreen" }
    }
  ]
}
