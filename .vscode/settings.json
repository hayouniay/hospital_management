{
  // ── Editor ────────────────────────────────────────────────────────────────
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.rulers": [100],
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.inlayHints.enabled": "on",
  "editor.semanticHighlighting.enabled": true,
  "editor.wordWrap": "off",

  // ── Files ─────────────────────────────────────────────────────────────────
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.encoding": "utf8",
  "files.eol": "\n",
  "files.exclude": {
    "**/build/**": true,
    "**/build-release/**": true,
    "**/build-debug/**": true,
    "**/.cache/**": true,
    "**/dist/**": false
  },
  "files.associations": {
    "*.h": "cpp",
    "*.cpp": "cpp",
    "*.qrc": "xml",
    "*.ui": "xml",
    "Makefile": "makefile"
  },

  // ── C/C++ Extension (ms-vscode.cpptools) ─────────────────────────────────
  "C_Cpp.default.cppStandard": "c++23",
  "C_Cpp.default.compilerPath": "/usr/bin/g++",
  "C_Cpp.default.intelliSenseMode": "linux-gcc-x64",
  "C_Cpp.default.compileCommands": "${workspaceFolder}/compile_commands.json",
  "C_Cpp.errorSquiggles": "enabled",
  "C_Cpp.autocomplete": "default",
  "C_Cpp.formatting": "clangFormat",
  "C_Cpp.clang_format_style": "file",
  "C_Cpp.clang_format_fallbackStyle": "{ BasedOnStyle: Google, IndentWidth: 4, ColumnLimit: 100, BreakBeforeBraces: Attach, AllowShortFunctionsOnASingleLine: Inline, SortIncludes: true }",

  // ── CMake Tools Extension ─────────────────────────────────────────────────
  "cmake.buildDirectory": "${workspaceFolder}/build",
  "cmake.configureArgs": [
    "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
  ],
  "cmake.buildBeforeRun": true,
  "cmake.saveBeforeBuild": true,
  "cmake.parallelJobs": 0,
  "cmake.statusbar.advanced": {
    "build": { "visibility": "compact" },
    "buildPreset": { "visibility": "hidden" },
    "launch": { "visibility": "compact" }
  },

  // ── Terminal ──────────────────────────────────────────────────────────────
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.gpuAcceleration": "on",
  "terminal.integrated.env.linux": {
    "TERM": "xterm-256color",
    "QT_QPA_PLATFORM": "xcb",
    "QT_LOGGING_RULES": "qt.qpa.*=false;*.warning=false"
  },

  // ── Search exclusions ────────────────────────────────────────────────────
  "search.exclude": {
    "**/build/**": true,
    "**/build-release/**": true,
    "**/build-debug/**": true,
    "**/dist/**": true,
    "**/.cache/**": true
  },

  // ── Extensions ───────────────────────────────────────────────────────────
  "extensions.ignoreRecommendations": false,

  // ── Git ──────────────────────────────────────────────────────────────────
  "git.autofetch": true,
  "git.confirmSync": false
}
